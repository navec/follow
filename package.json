{
  "name": "follow",
  "version": "0.1.0",
  "private": true,
  "description": "Hexagonal Express API with JWT auth (TypeScript, ESLint, Vitest)",
  "type": "module",
  "engines": {
    "node": ">=24.0.0 <25"
  },
  "scripts": {
    "dev": "tsx watch src/bootstrap/server.ts",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "start": "node dist/bootstrap/server.js",
    "db:migrate:up": "node-pg-migrate up -m src/infrastructure/persistence/postgres/migrations -d DATABASE_URL",
    "db:migrate:down": "node-pg-migrate down -m src/infrastructure/persistence/postgres/migrations -d DATABASE_URL",
    "db:migrate:status": "node-pg-migrate status -m src/infrastructure/persistence/postgres/migrations -d DATABASE_URL",
    "db:migrate:new": "node scripts/create-sql-migration.mjs",
    "db:test:create": "node scripts/create-test-db.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:unit": "vitest run src/domain src/application",
    "test:coverage": "vitest run --coverage.enabled --coverage.reporter=text --coverage.reporter=json-summary --coverage.reporter=lcov",
    "test:integration": "vitest run tests/integration"
  },
  "dependencies": {
    "argon2": "^0.41.1",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.17.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^5.4.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "node-pg-migrate": "^8.0.3",
    "supertest": "^7.1.1",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.0"
  }
}
